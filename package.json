{
  "name": "cryostat-openshift-console-plugin",
  "version": "4.3.0-dev",
  "description": "OpenShift Console plugin for Cryostat",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "src/cryostat-web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cryostatio/cryostat-openshift-console-plugin.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn webpack",
    "build-dev": "yarn clean && yarn webpack",
    "eslint": "yarn eslint:check",
    "eslint:check": "eslint './src/openshift/**/*.{ts,tsx,js}' './backend/src/**/*.{ts,tsx}' './cypress/**/*.{ts,tsx}'",
    "eslint:apply": "eslint --fix './src/openshift/**/*.{ts,tsx,js}' './backend/src/**/*.{ts,tsx}' './cypress/**/*.{ts,tsx}'",
    "stylelint:check": "stylelint 'src/openshift/**/*.css' --allow-empty-input",
    "stylelint:apply": "stylelint 'src/openshift/**/*.css' --fix",
    "license:check": "license-check-and-add check -f license-config.json",
    "license:apply": "license-check-and-add add -f license-config.json",
    "lint": "yarn lint:check",
    "lint:check": "concurrently -c 'auto' 'yarn:eslint:check' 'yarn:stylelint:check'",
    "lint:apply": "concurrently -c 'auto' 'yarn:eslint:apply' 'yarn:stylelint:apply'",
    "localize": "i18next \"src/openshift/**/*.{js,jsx,ts,tsx,json}\" -c ./i18next-parser.config.js",
    "format": "yarn format:check",
    "format:check": "concurrently -c 'auto' 'yarn:license:check' 'yarn:prettier:check'",
    "format:apply": "concurrently -c 'auto' 'yarn:license:apply' 'yarn:prettier:apply'",
    "prettier:check": "prettier --check './src/openshift/**/*.{tsx,ts}' './backend/src/**/*.{tsx,ts}' './cypress/**/*.{tsx,ts}'",
    "prettier:apply": "prettier --write './src/openshift/**/*.{tsx,ts}' './backend/src/**/*.{tsx,ts}' './cypress/**/*.{tsx,ts}'",
    "type-check": "tsc --noEmit",
    "type-check:plugin": "tsc --noEmit -p tsconfig-plugin.json",
    "start": "yarn webpack serve --progress",
    "start-console": "./start-console.sh",
    "i18n": "./i18n-scripts/build-i18n.sh && node ./i18n-scripts/set-english-defaults.js",
    "test": "jest src/openshift --maxWorkers=50% --coverage",
    "test:ci": "jest src/openshift --maxWorkers=50%",
    "cypress": "cd cypress && cypress open",
    "cypress:headed": "cd cypress && cypress run --headed",
    "cypress:headless": "cd cypress && cypress run --headless",
    "cypress:merge": "mochawesome-merge ./cypress/screenshots/cypress_report*.json > ./cypress/screenshots/cypress.json",
    "cypress:generate": "marge -o ./cypress/screenshots/ -f cypress-report -t 'Cryostat OpenShift Console Plugin Cypress Test Results' -p 'Cryostat OpenShift Console Plugin Cypress Test Results' --showPassed false --assetsDir ./cypress/screenshots/cypress/assets ./cypress/screenshots/cypress.json",
    "cypress:postreport": "yarn run cypress:merge && yarn run cypress:generate",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack",
    "mock-server": "prism mock -d -p 8181 $npm_package_config_api_schema_path"
  },
  "devDependencies": {
    "@babel/core": "7.29.6",
    "@babel/preset-env": "7.29.2",
    "@cypress/webpack-preprocessor": "6.0.4",
    "@monaco-editor/react": "4.7.0",
    "@openshift-console/dynamic-plugin-sdk": "4.19.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.19.0",
    "@patternfly/patternfly": "^6.0.0",
    "@patternfly/react-core": "^6.0.0",
    "@patternfly/react-icons": "^6.0.0",
    "@patternfly/react-topology": "^6.0.0",
    "@stoplight/prism-cli": "5.15.10",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.17",
    "@types/react": "^17.0.69",
    "@types/react-helmet": "^6.1.4",
    "@types/react-router-dom": "^5.3.2",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "babel-loader": "9.2.1",
    "concurrently": "9.2.1",
    "copy-webpack-plugin": "13.0.1",
    "css-loader": "7.1.4",
    "cypress": "15.14.1",
    "cypress-multi-reporters": "2.0.5",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "6.3.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "flat": "6.0.1",
    "i18next-parser": "9.4.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "license-check-and-add": "4.0.5",
    "mocha": "10.8.2",
    "mocha-junit-reporter": "2.2.1",
    "mochawesome": "7.1.4",
    "mochawesome-merge": "5.1.1",
    "pluralize": "8.0.0",
    "prettier": "3.8.3",
    "prettier-stylelint": "0.4.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-helmet": "^6.1.0",
    "react-router": "5.3.x",
    "react-router-dom": "5.3.x",
    "style-loader": "4.0.0",
    "stylelint": "17.10.0",
    "stylelint-config-standard": "40.0.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "typescript": "5.9.3",
    "webpack": "5.106.2",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "lodash": "4.18.1",
    "monaco-editor": "0.55.1",
    "react-redux": "7.2.9",
    "rxjs": "7.8.2"
  },
  "peerDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "babel-loader": "10.1.1",
    "i18next": "23.16.8",
    "mocha": "11.7.6"
  },
  "resolutions": {
    "@types/react": "17.0.93",
    "lodash": "4.18.1",
    "dompurify": "3.4.11"
  },
  "config": {
    "api_schema_path": "https://raw.githubusercontent.com/cryostatio/cryostat/refs/heads/main/schema/openapi.yaml"
  },
  "packageManager": "yarn@4.13.0"
}
